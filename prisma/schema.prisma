generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserType {
  ADMIN
  MANAGER
  TEAM_LEAD
  EMPLOYEE
  REPORT_VIEWER
  ACCOUNTS
}

enum FunctionalRoleCode {
  DEVELOPER
  QA
  DESIGNER
  LOCALIZATION
  DEVOPS
  PROJECT_MANAGER
  BILLING
  OTHER
}

enum BillingModel {
  HOURLY
  FIXED_FULL
  FIXED_MONTHLY
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum EstimateStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  REVISED
}

enum TimeEntryStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  REVISED
}

enum BillingTransactionType {
  PARTIAL_BILLING
  UPGRADE_PRE_COMPLETION
  UPGRADE_POST_COMPLETION
  ADJUSTMENT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  ACTIVATE
  DEACTIVATE
  SUBMIT
  APPROVE
  REJECT
  REVISE
  ASSIGN
  UNASSIGN
  CHANGE_PASSWORD
}

model Client {
  id          String    @id @default(cuid())
  name        String
  code        String?   @unique
  isActive    Boolean   @default(true)
  movies      Movie[]
  projects    Project[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Movie {
  id          String    @id @default(cuid())
  clientId    String
  title       String
  code        String?   @unique
  description String?   @db.Text
  isActive    Boolean   @default(true)
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  projects    Project[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([clientId])
}

model Country {
  id          String    @id @default(cuid())
  name        String
  isoCode     String?   @unique
  isActive    Boolean   @default(true)
  projects    ProjectCountry[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model EmployeeGroup {
  id          String    @id @default(cuid())
  name        String
  code        String?   @unique
  description String?   @db.Text
  isActive    Boolean   @default(true)
  users       UserEmployeeGroup[]
  projects    ProjectEmployeeGroup[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model User {
  id                     String                 @id @default(cuid())
  email                  String                 @unique
  username               String                 @unique
  passwordHash           String
  fullName               String
  userType               UserType
  functionalRole         FunctionalRoleCode?
  employeeCode           String?
  designation            String?
  joiningDate            DateTime?
  phoneNumber            String?
  currentAddress         String?                @db.Text
  permanentAddress       String?                @db.Text
  permanentSameAsCurrent Boolean                @default(false)
  isActive               Boolean                @default(true)
  createdProjects        Project[]              @relation("ProjectCreatedBy")
  updatedProjects        Project[]              @relation("ProjectUpdatedBy")
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  employeeGroups                UserEmployeeGroup[]
  teamLeadAssignmentsAsLead     EmployeeTeamLead[] @relation("EmployeeTeamLeadLead")
  teamLeadAssignmentsAsEmployee EmployeeTeamLead[] @relation("EmployeeTeamLeadEmployee")
  estimates                     Estimate[]
  timeEntries                   TimeEntry[]
  estimateReviews               EstimateReview[]
  timeEntryReviews              TimeEntryReview[]
  auditLogs                     AuditLog[]         @relation("AuditActor")
}

model UserEmployeeGroup {
  id               String        @id @default(cuid())
  userId           String
  employeeGroupId  String
  assignedAt       DateTime      @default(now())

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  employeeGroup EmployeeGroup @relation(fields: [employeeGroupId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, employeeGroupId])
  @@index([employeeGroupId])
}

model EmployeeTeamLead {
  id           String   @id @default(cuid())
  employeeId   String
  teamLeadId   String
  assignedAt   DateTime @default(now())
  assignedById String?

  employee User @relation("EmployeeTeamLeadEmployee", fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  teamLead User @relation("EmployeeTeamLeadLead", fields: [teamLeadId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([employeeId, teamLeadId])
  @@index([teamLeadId])
}

model Project {
  id                 String        @id @default(cuid())
  clientId           String
  movieId            String?
  code               String?       @unique
  name               String
  description        String?       @db.Text
  billingModel       BillingModel
  status             ProjectStatus @default(DRAFT)
  fixedContractHours Decimal?      @db.Decimal(10, 2)
  fixedMonthlyHours  Decimal?      @db.Decimal(10, 2)
  startDate          DateTime?
  endDate            DateTime?
  isActive           Boolean       @default(true)
  createdById        String?
  updatedById        String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  client         Client  @relation(fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  movie          Movie?  @relation(fields: [movieId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdBy      User?   @relation("ProjectCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  updatedBy      User?   @relation("ProjectUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: Cascade)

  countries           ProjectCountry[]
  employeeGroups      ProjectEmployeeGroup[]
  estimates           Estimate[]
  timeEntries         TimeEntry[]
  billingTransactions BillingTransaction[]

  @@index([clientId])
  @@index([movieId])
  @@index([status])
  @@index([billingModel])
}

model ProjectCountry {
  id         String   @id @default(cuid())
  projectId  String
  countryId  String
  assignedAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  country Country @relation(fields: [countryId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([projectId, countryId])
  @@index([countryId])
}

model ProjectEmployeeGroup {
  id              String   @id @default(cuid())
  projectId       String
  employeeGroupId String
  assignedAt      DateTime @default(now())

  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  employeeGroup EmployeeGroup @relation(fields: [employeeGroupId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([projectId, employeeGroupId])
  @@index([employeeGroupId])
}

model Estimate {
  id               String         @id @default(cuid())
  projectId        String
  employeeId       String
  countryId        String?
  workDate         DateTime
  estimatedMinutes Int
  notes            String?        @db.Text
  status           EstimateStatus @default(DRAFT)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  project  Project         @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  employee User            @relation(fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  reviews  EstimateReview[]

  @@index([projectId, workDate])
  @@index([employeeId, workDate])
  @@index([status])
}

model EstimateReview {
  id             String         @id @default(cuid())
  estimateId     String
  reviewerId     String
  decisionStatus EstimateStatus
  remarks        String?        @db.Text
  reviewedAt     DateTime       @default(now())

  estimate Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  reviewer User     @relation(fields: [reviewerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([reviewerId, reviewedAt])
}

model TimeEntry {
  id           String          @id @default(cuid())
  projectId    String
  employeeId   String
  countryId    String?
  workDate     DateTime
  taskName     String
  minutesSpent Int
  isBillable   Boolean         @default(true)
  notes        String?         @db.Text
  status       TimeEntryStatus @default(DRAFT)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  project  Project         @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  employee User            @relation(fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  reviews  TimeEntryReview[]

  @@index([projectId, workDate])
  @@index([employeeId, workDate])
  @@index([status])
}

model TimeEntryReview {
  id             String          @id @default(cuid())
  timeEntryId    String
  reviewerId     String
  decisionStatus TimeEntryStatus
  remarks        String?         @db.Text
  reviewedAt     DateTime        @default(now())

  timeEntry TimeEntry @relation(fields: [timeEntryId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  reviewer  User      @relation(fields: [reviewerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([reviewerId, reviewedAt])
}

model BillingTransaction {
  id              String                 @id @default(cuid())
  projectId       String
  transactionType BillingTransactionType
  amountHours     Decimal?               @db.Decimal(10, 2)
  amountMoney     Decimal?               @db.Decimal(12, 2)
  description     String?                @db.Text
  effectiveDate   DateTime
  createdAt       DateTime               @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([projectId, effectiveDate])
  @@index([transactionType])
}

model AuditLog {
  id            String      @id @default(cuid())
  actorUserId   String?
  entityType    String
  entityId      String
  action        AuditAction
  oldValuesJson String?     @db.LongText
  newValuesJson String?     @db.LongText
  notes         String?     @db.Text
  createdAt     DateTime    @default(now())

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([entityType, entityId])
  @@index([actorUserId, createdAt])
}
